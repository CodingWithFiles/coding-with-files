# Personal Claude Code settings (machine-specific, not for sharing)
.claude/settings.local.json

# CWF task stack (user-specific workspace state)
.cwf/task-stack

# CWF update lock (transient, runtime-only)
.cwf/.update.lock

# Scratchpad - working notes not to be committed
scratchpad.md
scratchpad

# Migration artifacts (v1.0 → v2.0)
.cig/migration-backup/
.cig/migration-state.json

# Silly files left around by macOS
.DS_Store
Thumbs.db
{
  "description" : "Structured task management system for software development using Claude Code integration",
  "directory-structure" : {
    "base-path" : "implementation-guide",
    "max-depth" : 5,
    "pattern" : "{{task-type}}/{{task-number}}-{{description-slug}}"
  },
  "integration" : {
    "claude-code" : {
      "autoload-config" : ".cwf/autoload.yaml",
      "commands-path" : ".claude/commands",
      "templates-path" : ".cwf/templates",
      "utils-path" : ".cwf/utils"
    }
  },
  "project-name" : "Coding with Files (CWF)",
  "security" : {
    "canonical-source" : {
      "base-url" : "https://api.github.com/repos/OWNER/REPO/contents",
      "repository" : "OWNER/REPO",
      "type" : "github",
      "verification-ref" : "main"
    },
    "file-integrity" : {
      "commands" : ".claude/commands/cwf-*.md",
      "hash-algorithm" : "sha256",
      "scripts" : ".cwf/scripts/command-helpers/cwf-*"
    },
    "version-tracking" : "v0.2.1"
  },
  "source-management" : {
    "branch-naming-convention" : "{task-type}/{task-id}-{description-slug}"
  },
  "supported-task-types" : [
    "feature",
    "bugfix",
    "hotfix",
    "chore",
    "discovery"
  ],
  "task-tracking" : {
    "base-url" : "https://github.com/anthropics/claude-code/issues",
    "fallback" : {
      "description" : "For tasks without GitHub issues yet",
      "id-format" : "internal-{{number}}",
      "migration-notes" : "Replace internal-N with issues-N when GitHub issue created"
    },
    "id-format" : "issues-{{number}}",
    "system" : "github-issues"
  },
  "templates" : {
    "bugfix" : [
      "plan.md",
      "implementation.md",
      "testing.md",
      "rollout.md"
    ],
    "chore" : [
      "plan.md",
      "implementation.md",
      "validation.md",
      "maintenance.md"
    ],
    "discovery" : [
      "plan.md",
      "requirements.md",
      "design.md",
      "implementation.md",
      "testing.md",
      "retrospective.md"
    ],
    "feature" : [
      "plan.md",
      "requirements.md",
      "design.md",
      "testing.md",
      "rollout.md",
      "maintenance.md"
    ],
    "hotfix" : [
      "plan.md",
      "implementation.md",
      "rollout.md"
    ]
  },
  "version" : "v0.2.1",
  "versioning" : {
    "last_released" : "v1.0.120",
    "major_minor" : "v1.0"
  },
  "wf_step_config" : {
    "retrospective" : {
      "bump_version" : true,
      "tag_version" : false
    }
  },
  "workflow" : {
    "required-sections" : [
      "Task Reference",
      "Goal",
      "Current Status"
    ],
    "status-values" : {
      "Backlog" : 0,
      "Blocked" : 15,
      "Cancelled" : 0,
      "Finished" : 100,
      "In Progress" : 25,
      "Skipped" : 100,
      "Testing" : 75,
      "To-Do" : 0
    }
  }
}

#!/usr/bin/env perl
#
# security-review-changeset - Construct the changeset reviewed by the
# exec-phase security-review subagent.
#
# Single source of truth for changeset construction (anchor + cap) in CWF.
# Called from the Step 8 of cwf-implementation-exec/SKILL.md and
# cwf-testing-exec/SKILL.md. Documents its contract in
# .cwf/docs/skills/security-review.md.
#
# Anchor resolution:
#   1. Read the task's a-task-plan.md for a `**Baseline Commit**: <sha>` line.
#   2. Fallback (in-flight tasks created before this field existed):
#      git merge-base HEAD <trunk>, where trunk is resolved from
#      cwf-project.json's optional top-level `trunk` field, or
#      git symbolic-ref refs/remotes/origin/HEAD, or hardcoded 'main'.
#      The resolved trunk name is validated by `git check-ref-format --branch`.
#
# Changeset scope:
#   The full diff (anchor → working tree) over every changed file, plus every
#   untracked, non-ignored file (so a new source file created before the exec
#   checkpoint commit is still reviewed). Untracked files are made diff-visible
#   via a transient `git add -N` (intent-to-add) and the index is restored on
#   every non-SIGKILL exit (END block + INT/TERM handlers). Ignored files are
#   excluded via git's --exclude-standard. No path, directory, or language
#   filtering — the security review must see every line the task ships.
#   Test-vs-production weighting applies only to the cap below.
#
# Production-weighted cap (--max-lines):
#   The full diff is always written to the .out file (see Output). The effective
#   cap resolves as --max-lines > security.review.max-lines (cwf-project.json) >
#   built-in default (1000); a malformed config value warns and degrades to the
#   default. The helper computes a production-weighted
#   line count: added+deleted lines (git diff --numstat) over the included files,
#   minus any path matching a `security.review.max-lines-exclude-paths` pattern
#   from cwf-project.json. Those patterns are gitignore/git pathspec globs,
#   applied by git's own :(glob,exclude) engine — no Perl-side path matching.
#   Default unset => no excludes => count == raw production lines. If the
#   production count exceeds the cap, the helper exits 2 (the .out file is
#   already written and the confirmation already printed). Unconfigured /
#   unmatched layouts count as production, so the cap fires earlier, never
#   later; a malformed pattern makes git fatal => capture_git exits 1.
#
# Agent contract:
#   This helper is designed to be run by an agent, invoked exactly as
#     .cwf/scripts/command-helpers/security-review-changeset --wf-step=<step>
#   with no surrounding boilerplate. It self-manages its output file and reports
#   the path + line count on stdout, so the agent needs no follow-up
#   redirect / wc / cat / grep.
#
# Usage:
#   security-review-changeset --wf-step=<step> [--task-num=NUM]
#                             [--max-lines=N] [--verbose]
#   <step> is one of the ten canonical workflow-step suffixes
#   (task-plan, requirements-plan, design-plan, implementation-plan,
#   testing-plan, implementation-exec, testing-exec, rollout, maintenance,
#   retrospective).
#
# Output:
#   File:   the full changeset (git diff, anchor → working tree) is written to
#           ${TMPDIR:-/tmp}/cwf<dashified-abs-main-root>/task-<num>/security-review-changeset-<step>.out
#           (mode 0600; parent and task-<num> leaf created mkdir 0700 on first use).
#           The agent Reads this file. An empty changeset still writes a 0-line file.
#   stdout: exactly one confirmation line —
#           `security-review-changeset: wrote <N> lines to <abs-path>`.
#   stderr: one-line summary
#           `reviewed N files, M lines (P production), anchor=<sha7>`,
#           with optional `, includes uncommitted` suffix when the working
#           tree has staged or unstaged changes OR any untracked, non-ignored
#           file is present (Task 141; Task 194 for untracked. Diff window
#           covers anchor to working tree, not just anchor..HEAD).
#           Plus one path per line under --verbose. On a cap breach, an
#           extra `cap exceeded: P production lines > N` line precedes exit 2.
#
# Exit:
#   0 ok (changeset may be empty — a 0-line .out file is still written)
#   1 error (missing/invalid --wf-step, unparseable branch, task not found,
#     malformed trunk, invalid --max-lines, uncreatable scratch dir, .out
#     write failure, malformed max-lines-exclude-paths pattern, etc.)
#   2 production-weighted line count exceeds --max-lines (.out file written +
#     confirmation printed before exit)

use strict;
use warnings;
use utf8;
use FindBin;
use lib "$FindBin::Bin/../../lib";
use CWF::Common qw(check_perl5opt scratch_dir);
use CWF::TaskPath qw(parse_branch resolve_num);
use CWF::ArtefactHelpers qw(atomic_write_text);

check_perl5opt();

my $PROG = 'security-review-changeset';

# Built-in production-weighted line cap. Effective cap resolves as
# CLI (--max-lines) > config (security.review.max-lines) > this default.
# Single source for the two live-code sites (the resolver and the
# interpolating print_usage POD); the plain-# header banner cannot
# interpolate and keeps its own hand-maintained numeric literal.
my $DEFAULT_MAX_LINES = 1000;

# ---------------------------------------------------------------------------
# Intent-to-add cleanup machinery (Task 194)
# Untracked, non-ignored files are made diff-visible via `git add -N` so the
# existing diff/numstat code paths render and count them. That mutates the
# index, so the entries MUST be restored on every exit path. The single END
# block below is the authoritative restore (it fires on normal exit, `exit 1`,
# the load-bearing `exit 2` cap, and `die`). It is best-effort and never
# `exit`s/`die`s itself, so it cannot mask the caller's exit code.
#   - `$$ == $MAIN_PID` guard: git_check() forks and its child can reach
#     `exit 127` (failed exec), which would otherwise run this END inside the
#     child. The guard makes END a no-op in ANY forked child.
#   - `system` (list form): shell-free (paths cannot be reinterpreted) and runs
#     no Perl END blocks (no recursion, no POSIX::_exit needed).
#   - `$? = $saved`: the reset must not alter the process exit code.
#   - `--` before the paths: option-injection defence (a file named `-rf` etc.).
# Signal handlers (installed on the mutating path, see main flow) call exit(),
# which runs this END, so an interrupt between `add -N` and exit still restores.
# ---------------------------------------------------------------------------
my @UNTRACKED_TO_RESET;
my $MAIN_PID = $$;
END {
    return unless $$ == $MAIN_PID;        # no-op in any forked child (incl. git_check's)
    return unless @UNTRACKED_TO_RESET;
    my $saved = $?;                        # preserve load-bearing exit code (e.g. exit 2)
    system('git', 'reset', '-q', '--', @UNTRACKED_TO_RESET);  # shell-free, runs no END
    warn "$PROG: warning: could not restore intent-to-add state\n" if $? != 0;
    $? = $saved;
}

# ---------------------------------------------------------------------------
# CLI parsing
# ---------------------------------------------------------------------------
# The ten canonical workflow-step skill suffixes. --wf-step is validated against
# this fixed literal set before it reaches any filesystem path, because the
# value becomes a component of the output filename (path-injection defence,
# NFR4). Mirrors the --task-num guard below.
my %WF_STEP = map { $_ => 1 } qw(
    task-plan requirements-plan design-plan implementation-plan testing-plan
    implementation-exec testing-exec rollout maintenance retrospective
);

my %opt = (wf_step => undef, task_num => undef, max_lines => undef, verbose => 0);
for my $arg (@ARGV) {
    if    ($arg =~ /^--wf-step=(.+)$/)   { $opt{wf_step} = $1 }
    elsif ($arg =~ /^--task-num=(.+)$/)  { $opt{task_num} = $1 }
    elsif ($arg =~ /^--max-lines=(.+)$/) { $opt{max_lines} = $1 }
    elsif ($arg eq '--verbose')          { $opt{verbose} = 1 }
    elsif ($arg eq '--help' || $arg eq '-h') {
        print_usage();
        exit 0;
    }
    else {
        warn "$PROG: unknown argument: $arg\n";
        exit 1;
    }
}

# --wf-step is mandatory and must be an allowlisted canonical step. A removed
# --phase, a typo, or a traversal-shaped value all land here.
unless (defined $opt{wf_step} && $WF_STEP{$opt{wf_step}}) {
    my $got = defined $opt{wf_step} ? "'$opt{wf_step}'" : '(missing)';
    warn "$PROG: invalid --wf-step $got (expected one of: "
       . join(', ', sort keys %WF_STEP) . ")\n";
    exit 1;
}

# Defence in depth: --task-num arrives from the command line. Validate
# before any FS access — guard against path-traversal-shaped values.
if (defined $opt{task_num} && $opt{task_num} !~ /^\d+(?:\.\d+)*$/) {
    warn "$PROG: invalid --task-num '$opt{task_num}' (expected /^\\d+(\\.\\d+)*\$/)\n";
    exit 1;
}

# --max-lines must be a positive integer (rejects 0, leading zeros, non-numeric).
# A bad CLI value is fatal (exit 1) — direct interactive input fails loud.
if (defined $opt{max_lines} && $opt{max_lines} !~ /^[1-9]\d*$/) {
    warn "$PROG: invalid --max-lines '$opt{max_lines}' (expected a positive integer)\n";
    exit 1;
}

# Effective cap: CLI flag (validated above) > config key > built-in default.
# Resolved after CLI validation so a config typo degrades safely (warn + default)
# while a CLI typo stays fatal above.
$opt{max_lines} = config_max_lines() // $DEFAULT_MAX_LINES
    unless defined $opt{max_lines};

# ---------------------------------------------------------------------------
# Resolve task number (from --task-num, else from current branch)
# ---------------------------------------------------------------------------
my $task_num = $opt{task_num};
unless (defined $task_num) {
    my $branch = capture_git('rev-parse', '--abbrev-ref', 'HEAD');
    chomp $branch;
    my ($num, $type, $slug) = parse_branch($branch);
    unless (defined $num) {
        warn "$PROG: branch '$branch' does not match pattern <type>/<num>-<slug>\n";
        exit 1;
    }
    $task_num = $num;
}

# ---------------------------------------------------------------------------
# Resolve task directory via the Perl module API
# ---------------------------------------------------------------------------
my $task_info = resolve_num($task_num);
unless ($task_info && $task_info->{full_path}) {
    warn "$PROG: task '$task_num' not found\n";
    exit 1;
}
my $task_dir = $task_info->{full_path};

# ---------------------------------------------------------------------------
# Resolve anchor: baseline-commit-in-a-task-plan, else fallback
# ---------------------------------------------------------------------------
my $anchor = resolve_anchor_from_baseline($task_dir);
$anchor //= resolve_anchor_from_fallback();

# ---------------------------------------------------------------------------
# List changed files between anchor and HEAD
# ---------------------------------------------------------------------------
my @changed = list_changed_files($anchor);

# ---------------------------------------------------------------------------
# Review the full changeset: every changed file, no path/language filter.
# Test-vs-production weighting happens only in the cap (count_production_lines).
#
# @included is assembled below (after the dirty probe + intent-to-add step) as
# (@changed, @untracked). Untracked enumeration MUST stay after the dirty probe
# so `git add -N` does not flip the `git diff --quiet HEAD` result 0->1.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Resolve the canonical per-task scratch dir, create it with the mandatory
# 0700 first-use guard, and write the changeset to
#   <scratch>/security-review-changeset-<wf-step>.out
# The scratch namespace is derived from the MAIN tree (find_git_root is
# worktree-safe per Task 173), so invocation from inside a linked worktree
# does not produce a divergent path (tmp-paths.md).
# ---------------------------------------------------------------------------
my $short = substr($anchor, 0, 7);
# Dirty probe BEFORE any intent-to-add (`git add -N` would flip this 0->1).
my $dirty_rc = git_check('diff', '--quiet', 'HEAD');

# Make untracked, non-ignored files diff-visible via intent-to-add so the
# unchanged diff/numstat code paths below render and count them. The index is
# restored by the END block (and signal handlers) on every non-SIGKILL exit.
my @untracked = list_untracked_files();
if (@untracked) {
    @UNTRACKED_TO_RESET = @untracked;   # END block resets exactly these paths
    # Install handlers BEFORE the index mutation: exit() runs the END block,
    # so an interrupt between `add -N` and normal exit still restores. Scoped
    # to the mutating path so unchanged runs keep default signal behaviour.
    $SIG{INT} = $SIG{TERM} = sub { exit(130); };
    capture_git('add', '-N', '--', @untracked);
}
# @included = tracked changes + untracked. Disjoint by construction (a path is
# either tracked-changed or untracked, never both), so no dedup. Explicit
# concat — do NOT re-run list_changed_files() after `add -N` (it would now also
# enumerate the untracked files and double-count). Over-count is the safe
# direction anyway (cap fires earlier, never later).
my @included = (@changed, @untracked);

# Suffix fires when tracked files are dirty OR any untracked file is present:
# an all-untracked changeset demonstrably includes uncommitted content.
my $dirty_suffix = ($dirty_rc == 1 || @untracked) ? ', includes uncommitted' : '';
# dirty_rc == 0 and no untracked: clean; rc >= 2: git error - skip suffix,
# don't fail. The primary diff has already succeeded; disclosure is informational.

# Derive + create the per-task scratch dir via the shared CWF::Common helper
# (Task 206): find_git_root (worktree-safe) + dashified ${TMPDIR:-/tmp} parent +
# two-level 0700 mkdir + symlink-parent reject, with NO auto-chmod (surface,
# never smooth). Any failure maps to this script's warn+exit-1 convention — the
# "error" classification the SubagentStop verdict guard relies on.
my ($scratch, $kind) = scratch_dir($task_num);
unless (defined $scratch) {
    warn "$PROG: scratch unavailable ($kind)\n";   # not_a_repo|bad_num|symlink_parent|mkdir_failed
    exit 1;
}
my $out = "$scratch/security-review-changeset-$opt{wf_step}.out";

# Unified path for empty and non-empty changesets: compute the diff ('' when no
# files changed), normalise to a trailing newline so the reported count equals
# `wc -l`, then write atomically. atomic_write_text uses a same-dir temp +
# rename, which REPLACES a pre-planted symlink rather than writing through it
# (referent untouched), and truncates any prior .out. It dies on failure; map
# that to this script's warn+exit-1 convention.
my $diff = @included ? capture_git('diff', "$anchor", '--', @included) : '';
$diff .= "\n" if length $diff && $diff !~ /\n\z/;
my $line_count = ($diff =~ tr/\n//);

eval { atomic_write_text($out, $diff, mode => 0600); 1 } or do {
    warn "$PROG: cannot write $out: $@";
    exit 1;
};

# The whole agent-facing contract: one confirmation line on stdout. No diff is
# ever written to stdout (the agent Reads the .out file).
print "$PROG: wrote $line_count lines to $out\n";

# Production-weighted count: added+deleted lines over the included files,
# minus any path matching a consumer-declared exclude glob. Git owns the
# matching (:(glob,exclude) magic pathspecs) — no Perl path classification.
my @exclude = max_lines_exclude_paths();
my $production = count_production_lines($anchor, \@included, \@exclude);

warn sprintf("reviewed %d files, %d lines (%d production), anchor=%s%s\n",
             scalar @included, $line_count, $production, $short, $dirty_suffix);
if ($opt{verbose}) {
    warn "  $_\n" for @included;
}

# Cap on production-weighted lines. The .out file is already written and the
# confirmation already printed, so the caller can still recover the path on
# exit 2. max_lines now always defined (default 1000) — no `defined` guard.
if ($production > $opt{max_lines}) {
    warn "cap exceeded: $production production lines > $opt{max_lines}\n";
    exit 2;
}
exit 0;

# ===========================================================================
# Subroutines
# ===========================================================================

sub print_usage {
    print <<"USAGE";
Usage: $PROG --wf-step=<step> [--task-num=NUM] [--max-lines=N] [--verbose]

Constructs the changeset reviewed by the exec-phase security-review subagent,
writes it to a per-task .out file, and prints the path + line count. Designed to
be run by an agent — invoke exactly as shown, with no surrounding boilerplate.

Options:
  --wf-step=STEP   REQUIRED. The calling workflow step; becomes a component of
                   the output filename. One of: task-plan, requirements-plan,
                   design-plan, implementation-plan, testing-plan,
                   implementation-exec, testing-exec, rollout, maintenance,
                   retrospective.
  --task-num=NUM   Override task-number inference from the current branch name.
                   NUM must match /^\\d+(\\.\\d+)*\$/.
  --max-lines=N    Cap on production-weighted lines (added+deleted over all changed
                   files, minus security.review.max-lines-exclude-paths globs). N is a
                   positive integer. Precedence: this flag > the config key
                   security.review.max-lines > built-in default ($DEFAULT_MAX_LINES).
                   A malformed config value warns and degrades to the default; a bad
                   flag value here is fatal (exit 1). When the count exceeds the
                   effective cap, exit 2 (the .out file is already written).
  --verbose        On stderr, list the included paths after the summary line.
  --help           Show this message.

Output:
  Writes the full diff to
    \${TMPDIR:-/tmp}/cwf<dashified-abs-main-root>/task-<num>/security-review-changeset-<step>.out
  and prints one confirmation line to stdout:
    $PROG: wrote <N> lines to <abs-path>

Exit codes:
  0  Changeset written (may be empty — a 0-line .out file is still written).
  1  Error.
  2  Production-weighted line count exceeds --max-lines (.out written first).
USAGE
}

# ---------------------------------------------------------------------------
# Run git with the given args; capture stdout. Dies on non-zero exit.
# Uses list-form open '-|' — never invokes a shell.
# ---------------------------------------------------------------------------
sub capture_git {
    my @args = @_;
    my $pid = open(my $fh, '-|', 'git', @args);
    unless ($pid) {
        warn "$PROG: cannot run git @args: $!\n";
        exit 1;
    }
    binmode $fh, ':raw';
    local $/;
    my $out = <$fh>;
    $out //= '';
    close $fh;
    if ($? != 0) {
        warn "$PROG: git @args exited with status " . ($? >> 8) . "\n";
        exit 1;
    }
    return $out;
}

# ---------------------------------------------------------------------------
# Run git with stdout/stderr suppressed; return exit status (0 = ok).
# ---------------------------------------------------------------------------
sub git_check {
    my @args = @_;
    my $pid = fork;
    unless (defined $pid) {
        warn "$PROG: fork failed: $!\n";
        exit 1;
    }
    if ($pid == 0) {
        # child: redirect stdout & stderr to /dev/null
        open(STDOUT, '>', '/dev/null');
        open(STDERR, '>', '/dev/null');
        # This child's `exit 127` (and any future exit here) must NOT run the
        # intent-to-add cleanup END block — that is the main process's job. The
        # `$$ == $MAIN_PID` guard in that END block is what protects this fork;
        # keep it intact if this fork site changes (e.g. POSIX::_exit, a 2nd fork).
        exec('git', @args) or exit 127;
    }
    waitpid($pid, 0);
    return $? == 0 ? 0 : ($? >> 8);
}

# ---------------------------------------------------------------------------
# Try to read the recorded baseline commit from <task-dir>/a-task-plan.md.
# Returns the SHA on success, undef on absent / format-unexpected.
# Emits a stderr warning when a `Baseline Commit:` line exists but does
# not match the strict format — falls back rather than failing hard.
# ---------------------------------------------------------------------------
sub resolve_anchor_from_baseline {
    my ($dir) = @_;
    my $plan = "$dir/a-task-plan.md";
    return undef unless -f $plan;

    open(my $fh, '<:encoding(UTF-8)', $plan)
        or return undef;
    my $found_line;
    my $found_sha;
    while (my $line = <$fh>) {
        next unless $line =~ /^- \*\*Baseline Commit\*\*:/;
        $found_line = $line;
        if ($line =~ /^- \*\*Baseline Commit\*\*:\s+([0-9a-f]{40})\s*$/) {
            $found_sha = $1;
        }
        last;  # only consider the first such line
    }
    close $fh;

    return undef unless defined $found_line;

    unless (defined $found_sha) {
        # Line present but malformed — warn and let caller fall back.
        warn "$PROG: warning: Baseline Commit line found but format unexpected; falling back to merge-base\n";
        return undef;
    }

    # Validate SHA points at a real commit reachable in this repo.
    my $rc = git_check('rev-parse', '--verify', '--quiet', "${found_sha}^{commit}");
    unless ($rc == 0) {
        warn "$PROG: warning: Baseline Commit '$found_sha' is not a valid commit object; falling back to merge-base\n";
        return undef;
    }
    return $found_sha;
}

# ---------------------------------------------------------------------------
# Fallback: resolve a trunk name (config / symbolic-ref / hardcoded), then
# anchor = merge-base HEAD <trunk>. Validates the trunk via
# `git check-ref-format --branch` to reject `..`, `.`, control chars, etc.
# Dies on unrecoverable failure.
# ---------------------------------------------------------------------------
sub resolve_anchor_from_fallback {
    my $trunk;

    # Tier 1: top-level "trunk" field in cwf-project.json (if readable).
    my $cfg = eval {
        require CWF::Versioning;
        CWF::Versioning::read_config();
    };
    if ($cfg && ref $cfg eq 'HASH' && defined $cfg->{trunk}) {
        $trunk = $cfg->{trunk};
    }

    # Tier 2: git's notion of the remote default branch.
    unless (defined $trunk) {
        my $rc = git_check('symbolic-ref', '--quiet', 'refs/remotes/origin/HEAD');
        if ($rc == 0) {
            my $name = capture_git('symbolic-ref', '--quiet', 'refs/remotes/origin/HEAD');
            chomp $name;
            $name =~ s{^refs/remotes/origin/}{};
            $trunk = $name if length $name;
        }
    }

    # Tier 3: hardcoded.
    $trunk //= 'main';

    # Validate via git itself — better than a hand-rolled regex.
    my $rc = git_check('check-ref-format', '--branch', $trunk);
    unless ($rc == 0) {
        warn "$PROG: trunk name '$trunk' is not a valid git branch reference\n";
        exit 1;
    }

    my $base = capture_git('merge-base', 'HEAD', $trunk);
    chomp $base;
    unless ($base =~ /^[0-9a-f]{40}$/) {
        warn "$PROG: merge-base HEAD $trunk did not return a SHA\n";
        exit 1;
    }
    return $base;
}

# ---------------------------------------------------------------------------
# git diff --name-only -z <anchor> → list of paths (anchor to working tree,
# includes staged + unstaged). Task 141: dropped `..HEAD` so the helper sees
# in-flight changes before the exec-phase checkpoint commit.
# ---------------------------------------------------------------------------
sub list_changed_files {
    my ($anchor) = @_;
    my $out = capture_git('diff', '--name-only', '-z', "$anchor");
    return () unless length $out;
    my @paths = split /\0/, $out;
    return grep { length } @paths;
}

# ---------------------------------------------------------------------------
# git ls-files --others --exclude-standard -z → list of untracked, non-ignored
# paths (Task 194). No $anchor: listing is anchor-independent (unlike the
# sibling list_changed_files, which genuinely diffs the anchor). Ignored files
# are dropped by --exclude-standard (git owns the matching — no Perl-side
# classification). NUL-split per the git-path-output convention.
# ---------------------------------------------------------------------------
sub list_untracked_files {
    my $out = capture_git('ls-files', '--others', '--exclude-standard', '-z');
    return () unless length $out;
    my @paths = grep { length } split /\0/, $out;
    # Keep only the path types `git add -N` can intent-to-add: regular files
    # (-f) and symlinks (-l). A sandbox harness may bind-mount /dev/null (a char
    # device) over repo-root config dotfiles; git enumerates those as untracked
    # but `git add -N` rejects them ("can only add regular files, symbolic links
    # or git-directories"), aborting the sweep. -l is lstat, so dangling symlinks
    # and symlinks-to-devices are retained (git stores their link text). Sibling
    # stop-stale-status-detector uses a bare -f; this site keeps -l because
    # untracked symlinks must stay reviewable (TC-GUARD1a / TC-209-1).
    return grep { -f $_ || -l $_ } @paths;
}

# ---------------------------------------------------------------------------
# Read consumer-declared exclude globs from cwf-project.json's
# security.review.max-lines-exclude-paths and return them as git exclude
# pathspecs. These paths are still REVIEWED (emitted in the diff) — they are
# only discounted from the --max-lines production count (e.g. tests, generated
# code, process docs). The repo owns the truth about its own layout (as a test
# runner's config already does); the helper does NO path matching itself.
# Reuses the eval-guarded read_config() (also used on the fallback anchor
# path): missing / unreadable / malformed config => empty list (never fatal,
# never a silent discount — unmatched paths count as production). Entries
# that are not non-empty NUL-free strings are skipped defensively.
# Back-compat: the former key name `test-paths` is still honoured (with a
# deprecation warning) when the new key is absent.
# ---------------------------------------------------------------------------
sub max_lines_exclude_paths {
    my $cfg = eval {
        require CWF::Versioning;
        CWF::Versioning::read_config();
    };
    return () unless $cfg && ref $cfg eq 'HASH';
    my $sec = $cfg->{security};
    return () unless ref $sec eq 'HASH';
    my $review = $sec->{review};
    return () unless ref $review eq 'HASH';
    my $paths = $review->{'max-lines-exclude-paths'};
    if (!defined $paths && defined $review->{'test-paths'}) {
        warn "$PROG: warning: 'security.review.test-paths' is deprecated; "
           . "rename it to 'security.review.max-lines-exclude-paths'\n";
        $paths = $review->{'test-paths'};
    }
    return () unless ref $paths eq 'ARRAY';

    my @excludes;
    for my $p (@$paths) {
        next if ref $p;                # skip nested structures
        next unless defined $p && length $p;
        next if $p =~ /\0/;            # NUL would corrupt the pathspec
        push @excludes, ":(glob,exclude)$p";
    }
    return @excludes;
}

# ---------------------------------------------------------------------------
# Read the optional production-line cap from security.review.max-lines in
# cwf-project.json. Mirrors max_lines_exclude_paths()'s defensive read.
# Returns a positive integer, or undef so the caller falls back to
# $DEFAULT_MAX_LINES. Fail-safe: any ambiguity degrades to the stricter
# default, never a larger/disabled cap.
#   - missing key / JSON null  => undef, SILENT (not configured, not a typo).
#   - ref (bool/array/object)  => undef, WARN  (an unambiguous typo).
#   - non-positive-integer     => undef, WARN  (reuses the CLI ^[1-9]\d*$
#     contract; a JSON number and a numeric string both stringify and match).
# The warning names the key only — no path or config contents echoed.
# ---------------------------------------------------------------------------
sub config_max_lines {
    my $cfg = eval {
        require CWF::Versioning;
        CWF::Versioning::read_config();
    };
    return undef unless $cfg && ref $cfg eq 'HASH';
    my $sec = $cfg->{security};
    return undef unless ref $sec eq 'HASH';
    my $review = $sec->{review};
    return undef unless ref $review eq 'HASH';
    my $v = $review->{'max-lines'};
    return undef unless defined $v;      # missing key / JSON null => silent default
    if (ref $v || "$v" !~ /^[1-9]\d*$/) {
        warn "$PROG: warning: 'security.review.max-lines' is not a positive "
           . "integer; using built-in default\n";
        return undef;
    }
    return "$v" + 0;
}

# ---------------------------------------------------------------------------
# Production-weighted line count: sum of added+deleted columns from
# `git diff --numstat <anchor> -- <included> <exclude-pathspecs>`. Git
# intersects the positive included paths with the exclude globs and reports
# only surviving files, so there is no Perl path classification and no
# diff-body parsing. Binary files (numstat reports `-`) count as 0. A
# malformed exclude pattern makes git fatal => capture_git exits 1 (safe
# fail). Returns 0 for an empty included list.
# ---------------------------------------------------------------------------
sub count_production_lines {
    my ($anchor, $included, $exclude) = @_;
    return 0 unless @$included;

    my $out = capture_git('diff', '--numstat', $anchor, '--', @$included, @$exclude);
    my $total = 0;
    for my $line (split /\n/, $out) {
        # numstat row: <added>\t<deleted>\t<path>. We only read the two
        # numeric columns, so path quoting/renames cannot misclassify.
        my ($added, $deleted) = split /\t/, $line;
        next unless defined $added && defined $deleted;
        $added   = 0 if $added   eq '-';   # binary
        $deleted = 0 if $deleted eq '-';
        next unless $added =~ /^\d+$/ && $deleted =~ /^\d+$/;
        $total += $added + $deleted;
    }
    return $total;
}

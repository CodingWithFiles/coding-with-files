#!/usr/bin/env perl
#
# security-review-changeset - Construct the changeset reviewed by the
# exec-phase security-review subagent.
#
# Single source of truth for changeset construction (anchor + cap) in CWF.
# Called from the Step 8 of cwf-implementation-exec/SKILL.md and
# cwf-testing-exec/SKILL.md. Documents its contract in
# .cwf/docs/skills/security-review.md.
#
# Anchor resolution:
#   1. Read the task's a-task-plan.md for a `**Baseline Commit**: <sha>` line.
#   2. Fallback (in-flight tasks created before this field existed):
#      git merge-base HEAD <trunk>, where trunk is resolved from
#      cwf-project.json's optional top-level `trunk` field, or
#      git symbolic-ref refs/remotes/origin/HEAD, or hardcoded 'main'.
#      The resolved trunk name is validated by `git check-ref-format --branch`.
#
# Changeset scope:
#   The full diff (anchor → working tree) over every changed file. No path,
#   directory, or language filtering — the security review must see every line
#   the task ships. Test-vs-production weighting applies only to the cap below.
#
# Production-weighted cap (--max-lines):
#   The full diff is always emitted to stdout. When --max-lines=N is given,
#   the helper also computes a production-weighted line count: added+deleted
#   lines (git diff --numstat) over the included files, minus any path
#   matching a `security.review.max-lines-exclude-paths` pattern from cwf-project.json.
#   Those patterns are gitignore/git pathspec globs, applied by git's own
#   :(glob,exclude) engine — no Perl-side path matching. Default unset =>
#   no excludes => count == raw production lines. If the production count
#   exceeds N, the helper exits 2 (stdout already printed). Unconfigured /
#   unmatched layouts count as production, so the cap fires earlier, never
#   later; a malformed pattern makes git fatal => capture_git exits 1.
#
# Usage:
#   security-review-changeset [--phase=implementation|testing] [--task-num=NUM]
#                             [--max-lines=N] [--verbose]
#
# Output:
#   stdout: git diff output (the full changeset for the subagent).
#   stderr: one-line summary
#           `reviewed N files, M lines (P production), anchor=<sha7>`,
#           with optional `, includes uncommitted` suffix when the working
#           tree has staged or unstaged changes (Task 141; diff window
#           covers anchor to working tree, not just anchor..HEAD).
#           Plus one path per line under --verbose. On a cap breach, an
#           extra `cap exceeded: P production lines > N` line precedes exit 2.
#
# Exit:
#   0 ok (changeset may be empty)
#   1 error (unparseable branch, task not found, malformed trunk,
#     invalid --max-lines, malformed max-lines-exclude-paths pattern, etc.)
#   2 production-weighted line count exceeds --max-lines (changeset on stdout)

use strict;
use warnings;
use utf8;
use FindBin;
use lib "$FindBin::Bin/../../lib";
use CWF::Common qw(check_perl5opt);
use CWF::TaskPath qw(parse_branch resolve_num);

check_perl5opt();

my $PROG = 'security-review-changeset';

# ---------------------------------------------------------------------------
# CLI parsing
# ---------------------------------------------------------------------------
my %opt = (phase => undef, task_num => undef, max_lines => undef, verbose => 0);
for my $arg (@ARGV) {
    if    ($arg =~ /^--phase=(implementation|testing)$/) { $opt{phase} = $1 }
    elsif ($arg =~ /^--task-num=(.+)$/)                  { $opt{task_num} = $1 }
    elsif ($arg =~ /^--max-lines=(.+)$/)                 { $opt{max_lines} = $1 }
    elsif ($arg eq '--verbose')                          { $opt{verbose} = 1 }
    elsif ($arg eq '--help' || $arg eq '-h') {
        print_usage();
        exit 0;
    }
    else {
        warn "$PROG: unknown argument: $arg\n";
        exit 1;
    }
}

# Defence in depth: --task-num arrives from the command line. Validate
# before any FS access — guard against path-traversal-shaped values.
if (defined $opt{task_num} && $opt{task_num} !~ /^\d+(?:\.\d+)*$/) {
    warn "$PROG: invalid --task-num '$opt{task_num}' (expected /^\\d+(\\.\\d+)*\$/)\n";
    exit 1;
}

# --max-lines must be a positive integer (rejects 0, leading zeros, non-numeric).
if (defined $opt{max_lines} && $opt{max_lines} !~ /^[1-9]\d*$/) {
    warn "$PROG: invalid --max-lines '$opt{max_lines}' (expected a positive integer)\n";
    exit 1;
}

# ---------------------------------------------------------------------------
# Resolve task number (from --task-num, else from current branch)
# ---------------------------------------------------------------------------
my $task_num = $opt{task_num};
unless (defined $task_num) {
    my $branch = capture_git('rev-parse', '--abbrev-ref', 'HEAD');
    chomp $branch;
    my ($num, $type, $slug) = parse_branch($branch);
    unless (defined $num) {
        warn "$PROG: branch '$branch' does not match pattern <type>/<num>-<slug>\n";
        exit 1;
    }
    $task_num = $num;
}

# ---------------------------------------------------------------------------
# Resolve task directory via the Perl module API
# ---------------------------------------------------------------------------
my $task_info = resolve_num($task_num);
unless ($task_info && $task_info->{full_path}) {
    warn "$PROG: task '$task_num' not found\n";
    exit 1;
}
my $task_dir = $task_info->{full_path};

# ---------------------------------------------------------------------------
# Resolve anchor: baseline-commit-in-a-task-plan, else fallback
# ---------------------------------------------------------------------------
my $anchor = resolve_anchor_from_baseline($task_dir);
$anchor //= resolve_anchor_from_fallback();

# ---------------------------------------------------------------------------
# List changed files between anchor and HEAD
# ---------------------------------------------------------------------------
my @changed = list_changed_files($anchor);

# ---------------------------------------------------------------------------
# Review the full changeset: every changed file, no path/language filter.
# Test-vs-production weighting happens only in the cap (count_production_lines).
# ---------------------------------------------------------------------------
my @included = @changed;

# ---------------------------------------------------------------------------
# Emit the full diff (or empty changeset) and stderr summary
# ---------------------------------------------------------------------------
my $short = substr($anchor, 0, 7);
my $dirty_rc = git_check('diff', '--quiet', 'HEAD');
my $dirty_suffix = $dirty_rc == 1 ? ', includes uncommitted' : '';
# dirty_rc == 0: clean; rc >= 2: git error - skip suffix, don't fail.
# The primary diff has already succeeded; the disclosure is informational.

if (!@included) {
    warn "reviewed 0 files, 0 lines (0 production), anchor=$short$dirty_suffix\n";
    exit 0;
}

my $diff = capture_git('diff', "$anchor", '--', @included);
my $line_count = ($diff =~ tr/\n//);
print $diff;

# Production-weighted count: added+deleted lines over the included files,
# minus any path matching a consumer-declared test-path glob. Git owns the
# matching (:(glob,exclude) magic pathspecs) — no Perl path classification.
my @exclude = max_lines_exclude_paths();
my $production = count_production_lines($anchor, \@included, \@exclude);

warn sprintf("reviewed %d files, %d lines (%d production), anchor=%s%s\n",
             scalar @included, $line_count, $production, $short, $dirty_suffix);
if ($opt{verbose}) {
    warn "  $_\n" for @included;
}

# Cap on production-weighted lines (stdout already carries the full diff).
if (defined $opt{max_lines} && $production > $opt{max_lines}) {
    warn "cap exceeded: $production production lines > $opt{max_lines}\n";
    exit 2;
}
exit 0;

# ===========================================================================
# Subroutines
# ===========================================================================

sub print_usage {
    print <<"USAGE";
Usage: $PROG [--phase=implementation|testing] [--task-num=NUM]
                            [--max-lines=N] [--verbose]

Constructs the changeset reviewed by the exec-phase security-review subagent.

Options:
  --phase=PHASE    Identify the calling exec phase (informational; no behavioural
                   effect on the changeset). PHASE is 'implementation' or 'testing'.
  --task-num=NUM   Override task-number inference from the current branch name.
                   NUM must match /^\\d+(\\.\\d+)*\$/.
  --max-lines=N    Cap on production-weighted lines (added+deleted over all changed
                   files, minus security.review.max-lines-exclude-paths globs). N is a
                   positive integer. When the count exceeds N, exit 2 after emitting the diff.
  --verbose        On stderr, list the included paths after the summary line.
  --help           Show this message.

Exit codes:
  0  Changeset emitted (may be empty).
  1  Error.
  2  Production-weighted line count exceeds --max-lines (changeset on stdout).
USAGE
}

# ---------------------------------------------------------------------------
# Run git with the given args; capture stdout. Dies on non-zero exit.
# Uses list-form open '-|' — never invokes a shell.
# ---------------------------------------------------------------------------
sub capture_git {
    my @args = @_;
    my $pid = open(my $fh, '-|', 'git', @args);
    unless ($pid) {
        warn "$PROG: cannot run git @args: $!\n";
        exit 1;
    }
    binmode $fh, ':raw';
    local $/;
    my $out = <$fh>;
    $out //= '';
    close $fh;
    if ($? != 0) {
        warn "$PROG: git @args exited with status " . ($? >> 8) . "\n";
        exit 1;
    }
    return $out;
}

# ---------------------------------------------------------------------------
# Run git with stdout/stderr suppressed; return exit status (0 = ok).
# ---------------------------------------------------------------------------
sub git_check {
    my @args = @_;
    my $pid = fork;
    unless (defined $pid) {
        warn "$PROG: fork failed: $!\n";
        exit 1;
    }
    if ($pid == 0) {
        # child: redirect stdout & stderr to /dev/null
        open(STDOUT, '>', '/dev/null');
        open(STDERR, '>', '/dev/null');
        exec('git', @args) or exit 127;
    }
    waitpid($pid, 0);
    return $? == 0 ? 0 : ($? >> 8);
}

# ---------------------------------------------------------------------------
# Try to read the recorded baseline commit from <task-dir>/a-task-plan.md.
# Returns the SHA on success, undef on absent / format-unexpected.
# Emits a stderr warning when a `Baseline Commit:` line exists but does
# not match the strict format — falls back rather than failing hard.
# ---------------------------------------------------------------------------
sub resolve_anchor_from_baseline {
    my ($dir) = @_;
    my $plan = "$dir/a-task-plan.md";
    return undef unless -f $plan;

    open(my $fh, '<:encoding(UTF-8)', $plan)
        or return undef;
    my $found_line;
    my $found_sha;
    while (my $line = <$fh>) {
        next unless $line =~ /^- \*\*Baseline Commit\*\*:/;
        $found_line = $line;
        if ($line =~ /^- \*\*Baseline Commit\*\*:\s+([0-9a-f]{40})\s*$/) {
            $found_sha = $1;
        }
        last;  # only consider the first such line
    }
    close $fh;

    return undef unless defined $found_line;

    unless (defined $found_sha) {
        # Line present but malformed — warn and let caller fall back.
        warn "$PROG: warning: Baseline Commit line found but format unexpected; falling back to merge-base\n";
        return undef;
    }

    # Validate SHA points at a real commit reachable in this repo.
    my $rc = git_check('rev-parse', '--verify', '--quiet', "${found_sha}^{commit}");
    unless ($rc == 0) {
        warn "$PROG: warning: Baseline Commit '$found_sha' is not a valid commit object; falling back to merge-base\n";
        return undef;
    }
    return $found_sha;
}

# ---------------------------------------------------------------------------
# Fallback: resolve a trunk name (config / symbolic-ref / hardcoded), then
# anchor = merge-base HEAD <trunk>. Validates the trunk via
# `git check-ref-format --branch` to reject `..`, `.`, control chars, etc.
# Dies on unrecoverable failure.
# ---------------------------------------------------------------------------
sub resolve_anchor_from_fallback {
    my $trunk;

    # Tier 1: top-level "trunk" field in cwf-project.json (if readable).
    my $cfg = eval {
        require CWF::Versioning;
        CWF::Versioning::read_config();
    };
    if ($cfg && ref $cfg eq 'HASH' && defined $cfg->{trunk}) {
        $trunk = $cfg->{trunk};
    }

    # Tier 2: git's notion of the remote default branch.
    unless (defined $trunk) {
        my $rc = git_check('symbolic-ref', '--quiet', 'refs/remotes/origin/HEAD');
        if ($rc == 0) {
            my $name = capture_git('symbolic-ref', '--quiet', 'refs/remotes/origin/HEAD');
            chomp $name;
            $name =~ s{^refs/remotes/origin/}{};
            $trunk = $name if length $name;
        }
    }

    # Tier 3: hardcoded.
    $trunk //= 'main';

    # Validate via git itself — better than a hand-rolled regex.
    my $rc = git_check('check-ref-format', '--branch', $trunk);
    unless ($rc == 0) {
        warn "$PROG: trunk name '$trunk' is not a valid git branch reference\n";
        exit 1;
    }

    my $base = capture_git('merge-base', 'HEAD', $trunk);
    chomp $base;
    unless ($base =~ /^[0-9a-f]{40}$/) {
        warn "$PROG: merge-base HEAD $trunk did not return a SHA\n";
        exit 1;
    }
    return $base;
}

# ---------------------------------------------------------------------------
# git diff --name-only -z <anchor> → list of paths (anchor to working tree,
# includes staged + unstaged). Task 141: dropped `..HEAD` so the helper sees
# in-flight changes before the exec-phase checkpoint commit.
# ---------------------------------------------------------------------------
sub list_changed_files {
    my ($anchor) = @_;
    my $out = capture_git('diff', '--name-only', '-z', "$anchor");
    return () unless length $out;
    my @paths = split /\0/, $out;
    return grep { length } @paths;
}

# ---------------------------------------------------------------------------
# Read consumer-declared exclude globs from cwf-project.json's
# security.review.max-lines-exclude-paths and return them as git exclude
# pathspecs. These paths are still REVIEWED (emitted in the diff) — they are
# only discounted from the --max-lines production count (e.g. tests, generated
# code, process docs). The repo owns the truth about its own layout (as a test
# runner's config already does); the helper does NO path matching itself.
# Reuses the eval-guarded read_config() (also used on the fallback anchor
# path): missing / unreadable / malformed config => empty list (never fatal,
# never a silent discount — unmatched paths count as production). Entries
# that are not non-empty NUL-free strings are skipped defensively.
# Back-compat: the former key name `test-paths` is still honoured (with a
# deprecation warning) when the new key is absent.
# ---------------------------------------------------------------------------
sub max_lines_exclude_paths {
    my $cfg = eval {
        require CWF::Versioning;
        CWF::Versioning::read_config();
    };
    return () unless $cfg && ref $cfg eq 'HASH';
    my $sec = $cfg->{security};
    return () unless ref $sec eq 'HASH';
    my $review = $sec->{review};
    return () unless ref $review eq 'HASH';
    my $paths = $review->{'max-lines-exclude-paths'};
    if (!defined $paths && defined $review->{'test-paths'}) {
        warn "$PROG: warning: 'security.review.test-paths' is deprecated; "
           . "rename it to 'security.review.max-lines-exclude-paths'\n";
        $paths = $review->{'test-paths'};
    }
    return () unless ref $paths eq 'ARRAY';

    my @excludes;
    for my $p (@$paths) {
        next if ref $p;                # skip nested structures
        next unless defined $p && length $p;
        next if $p =~ /\0/;            # NUL would corrupt the pathspec
        push @excludes, ":(glob,exclude)$p";
    }
    return @excludes;
}

# ---------------------------------------------------------------------------
# Production-weighted line count: sum of added+deleted columns from
# `git diff --numstat <anchor> -- <included> <exclude-pathspecs>`. Git
# intersects the positive included paths with the exclude globs and reports
# only surviving files, so there is no Perl path classification and no
# diff-body parsing. Binary files (numstat reports `-`) count as 0. A
# malformed exclude pattern makes git fatal => capture_git exits 1 (safe
# fail). Returns 0 for an empty included list.
# ---------------------------------------------------------------------------
sub count_production_lines {
    my ($anchor, $included, $exclude) = @_;
    return 0 unless @$included;

    my $out = capture_git('diff', '--numstat', $anchor, '--', @$included, @$exclude);
    my $total = 0;
    for my $line (split /\n/, $out) {
        # numstat row: <added>\t<deleted>\t<path>. We only read the two
        # numeric columns, so path quoting/renames cannot misclassify.
        my ($added, $deleted) = split /\t/, $line;
        next unless defined $added && defined $deleted;
        $added   = 0 if $added   eq '-';   # binary
        $deleted = 0 if $deleted eq '-';
        next unless $added =~ /^\d+$/ && $deleted =~ /^\d+$/;
        $total += $added + $deleted;
    }
    return $total;
}

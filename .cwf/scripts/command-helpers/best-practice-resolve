#!/usr/bin/env perl
#
# best-practice-resolve - Select the best-practice doc entries whose tags apply
# to a task and hand the reviewer their paths, verbatim.
#
# A config entry is a plain pointer: `{ documentation: <path>, tags: [...] }`.
# This helper does the one deterministic job — read the config(s), work out
# which tags apply to the task, and emit the matched entries' paths. That is
# all. There is no existence check, no path confinement, no de-duplication, no
# directory listing: the reviewer subagent is handed the path verbatim and
# figures the rest out (Read a file, Glob a directory). See
# .cwf/docs/skills/best-practice-review.md for the contract.
#
# Config (.cwf/docs/skills/best-practice-review.md owns the schema reference):
#   best-practices.json is read from BOTH the project location
#   (<git-root>/.cwf/best-practices.json) and the user location
#   (~/.cwf/best-practices.json). Both load and merge; project entries take
#   precedence over user entries on collision (same `documentation`).
#   active-tags is unioned. A whole file that is not valid JSON degrades to zero
#   entries from that file with a diagnostic (never an abort). A schema-invalid
#   entry (missing `documentation` or empty `tags`) is skipped with a diagnostic
#   naming it; the remaining valid entries still load. Unknown keys are ignored.
#
# Task tags (T):
#   T = union of (a) active-tags from the merged config and (b) an optional
#   per-task `- **Tags**: a, b, c` line in the task's a-task-plan.md Task
#   Reference block. Undeclared == empty == zero matches (no review work).
#   Matching is exact-token, case-normalised (lc) intersection; no substring.
#
# Usage:
#   best-practice-resolve --task-num=NUM --phase=PHASE
#   PHASE is one of plan, implementation-exec, testing-exec (it becomes a
#   component of the output filename, so it is allowlist-validated).
#
# Output:
#   File:   /tmp/claude-<euid>/cwf<dashified-abs-main-root>/task-<num>/best-practice-context-<phase>.out
#           (mode 0600; base, cwf<root> parent, and task-<num> leaf created mkdir 0700 on first use).
#           One `- <tags>: <path>` line per matched entry, path verbatim.
#   stdout: exactly one confirmation line —
#           `best-practice-resolve: wrote <N> matched entries to <abs-path>`.
#   stderr: config diagnostics (unparseable file, schema-invalid entry, task
#           not found) — surfaced, never fatal.
#
# Exit:
#   0 ok (including 0 matches -> a near-empty file is still written)
#   1 resolution failure (bad args, unresolvable git root, uncreatable scratch
#     dir, .out write failure). A broken config is NOT exit 1 (fail-open).
#
use strict;
use warnings;
use utf8;
use FindBin;
use lib "$FindBin::Bin/../../lib";
use CWF::Common qw(check_perl5opt find_git_root scratch_dir scratch_fail_hint);
use CWF::TaskPath qw(resolve_num);
use CWF::ArtefactHelpers qw(atomic_write_text);
use JSON::PP ();

check_perl5opt();

my $PROG = 'best-practice-resolve';

# --phase allowlist: the value becomes a filename component, so it is validated
# against this fixed literal set before reaching any filesystem path.
my %PHASE = map { $_ => 1 } qw(plan implementation-exec testing-exec);

my $ROOT;

# ---------------------------------------------------------------------------
# CLI parsing
# ---------------------------------------------------------------------------
my %opt = (task_num => undef, phase => undef);
for my $arg (@ARGV) {
    if    ($arg =~ /^--task-num=(.+)$/)  { $opt{task_num}  = $1 }
    elsif ($arg =~ /^--phase=(.+)$/)     { $opt{phase}     = $1 }
    elsif ($arg eq '--help' || $arg eq '-h') { print_usage(); exit 0 }
    else { warn "$PROG: unknown argument: $arg\n"; exit 1 }
}

# --task-num is mandatory and becomes a filename component (path-injection guard).
unless (defined $opt{task_num} && $opt{task_num} =~ /^\d+(?:\.\d+)*$/) {
    my $got = defined $opt{task_num} ? "'$opt{task_num}'" : '(missing)';
    warn "$PROG: invalid --task-num $got (expected /^\\d+(\\.\\d+)*\$/)\n";
    exit 1;
}
# --phase is mandatory + allowlisted; it too becomes a filename component.
unless (defined $opt{phase} && $PHASE{$opt{phase}}) {
    my $got = defined $opt{phase} ? "'$opt{phase}'" : '(missing)';
    warn "$PROG: invalid --phase $got (expected one of: "
       . join(', ', sort keys %PHASE) . ")\n";
    exit 1;
}

# ---------------------------------------------------------------------------
# Resolve the main git root (worktree-safe) — used only to locate the project
# config and name the scratch dir.
# ---------------------------------------------------------------------------
$ROOT = find_git_root();
unless (defined $ROOT && length $ROOT) {
    warn "$PROG: cannot resolve git repository root\n";
    exit 1;
}
$ROOT =~ s{/+$}{};

# ---------------------------------------------------------------------------
# Load + merge config from project then user locations.
# Project is processed first, so project entries win on collision.
# ---------------------------------------------------------------------------
my @entries;          # merged best-practice entries, project-first order
my %seen_doc;         # documentation-string => 1 (merge precedence key)
my %active_tags;      # lc tag => original (union)

for my $loc (["$ROOT/.cwf/best-practices.json"],
             [(defined $ENV{HOME} && length $ENV{HOME})
                  ? "$ENV{HOME}/.cwf/best-practices.json" : undef]) {
    my ($path) = @$loc;
    next unless defined $path && -e $path;
    my $cfg = load_config($path);
    next unless defined $cfg;
    merge_config($cfg, $path);
}

# ---------------------------------------------------------------------------
# Compute the applicable tag set T = active-tags ∪ per-task **Tags**.
# ---------------------------------------------------------------------------
my %T = %active_tags;
my $task = resolve_num($opt{task_num});
if ($task && $task->{full_path}) {
    for my $t (read_task_tags("$task->{full_path}/a-task-plan.md")) {
        $T{ lc $t } = $t;
    }
} else {
    warn "$PROG: warning: task '$opt{task_num}' not found; using active-tags only\n";
}

# ---------------------------------------------------------------------------
# Match: an entry applies iff any of its (lc) tags is in T. The matched
# entry's path is handed to the reviewer verbatim.
# ---------------------------------------------------------------------------
my @matched = grep { entry_matches($_, \%T) } @entries;

my $out = scratch_out_path();
eval { atomic_write_text($out, render(\@matched), mode => 0600); 1 } or do {
    warn "$PROG: cannot write $out: $@";
    exit 1;
};

print "$PROG: wrote " . scalar(@matched) . " matched entries to $out\n";
exit 0;

# ===========================================================================
# Subroutines
# ===========================================================================

sub print_usage {
    print <<"USAGE";
Usage: $PROG --task-num=NUM --phase=PHASE

Selects the best-practice doc entries whose tags apply to the task and writes
their paths (verbatim) for the planning/exec reviewer subagents. Designed to be
run by an agent — invoke exactly as shown, with no surrounding boilerplate.

Options:
  --task-num=NUM   REQUIRED. Task number (/^\\d+(\\.\\d+)*\$/). Selects the
                   task whose a-task-plan.md supplies per-task tags, and names
                   the per-task scratch dir.
  --phase=PHASE    REQUIRED. One of: plan, implementation-exec, testing-exec.
                   Becomes a component of the output filename so a planning run
                   and the two exec runs for one task never clobber each other.
  --help           Show this message.

Output:
  Writes the matched paths to
    /tmp/claude-<euid>/cwf<dashified-abs-main-root>/task-<num>/best-practice-context-<phase>.out
  and prints one confirmation line to stdout:
    $PROG: wrote <N> matched entries to <abs-path>

Exit codes:
  0  Written (N may be 0). A malformed config is fail-open, not exit 1.
  1  Resolution failure (bad args, unresolvable root, scratch/.out write failure).
USAGE
}

# Read + JSON-decode a config file. eval-wrapped: a whole file that is not
# valid JSON degrades to undef with a diagnostic — never fatal.
sub load_config {
    my ($path) = @_;
    open(my $fh, '<:raw', $path) or do {
        warn "$PROG: warning: cannot read config $path: $!\n";
        return undef;
    };
    local $/;
    my $blob = <$fh>;
    close $fh;
    my $data = eval { JSON::PP->new->utf8->decode($blob) };
    if ($@ || !defined $data) {
        warn "$PROG: warning: config $path is not valid JSON; ignoring it (0 entries)\n";
        return undef;
    }
    unless (ref $data eq 'HASH') {
        warn "$PROG: warning: config $path is not a JSON object; ignoring it (0 entries)\n";
        return undef;
    }
    return $data;
}

# Merge one decoded config into the accumulators. Project is merged first.
sub merge_config {
    my ($cfg, $path) = @_;

    # active-tags: union.
    if (ref $cfg->{'active-tags'} eq 'ARRAY') {
        for my $t (@{ $cfg->{'active-tags'} }) {
            next if ref $t || !defined $t || !length $t;
            $active_tags{ lc $t } = $t;
        }
    }

    # best-practices[]: validate + de-dup by documentation string.
    my $bp = $cfg->{'best-practices'};
    unless (ref $bp eq 'ARRAY') {
        warn "$PROG: warning: config $path has no 'best-practices' array; "
           . "0 entries from it\n" if exists $cfg->{'best-practices'};
        return;
    }
    my $i = -1;
    for my $entry (@$bp) {
        $i++;
        unless (ref $entry eq 'HASH') {
            warn "$PROG: warning: config entry #$i is not an object; skipped\n";
            next;
        }
        my $doc  = $entry->{documentation};
        my $tags = $entry->{tags};
        unless (defined $doc && !ref $doc && length $doc) {
            warn "$PROG: warning: config entry #$i lacks a non-empty "
               . "'documentation'; skipped\n";
            next;
        }
        my @clean_tags = grep { defined && !ref && length } (ref $tags eq 'ARRAY' ? @$tags : ());
        unless (@clean_tags) {
            warn "$PROG: warning: config entry #$i ('$doc') has empty 'tags'; skipped\n";
            next;
        }
        next if $seen_doc{$doc}++;   # project (merged first) wins on collision
        push @entries, { documentation => $doc, tags => \@clean_tags };
    }
}

# Read the optional per-task `- **Tags**: a, b, c` line from a-task-plan.md.
sub read_task_tags {
    my ($plan) = @_;
    return () unless -f $plan;
    open(my $fh, '<:encoding(UTF-8)', $plan) or return ();
    my @tags;
    while (my $line = <$fh>) {
        next unless $line =~ /^- \*\*Tags\*\*:\s*(.+?)\s*$/;
        @tags = grep { length } map { s/^\s+|\s+$//gr } split /,/, $1;
        last;
    }
    close $fh;
    return @tags;
}

sub entry_matches {
    my ($entry, $T) = @_;
    for my $t (@{ $entry->{tags} }) {
        return 1 if exists $T->{ lc $t };
    }
    return 0;
}

# The .out: one `- <tags>: <path>` line per matched entry, path verbatim.
sub render {
    my ($matched) = @_;
    my @tags = sort values %T;
    my $out = "# Best-practice sources for task $opt{task_num}"
            . " (applicable tags: " . (@tags ? join(', ', @tags) : '(none)') . ")\n";
    if (@$matched) {
        for my $e (@$matched) {
            $out .= "- " . join(', ', @{ $e->{tags} }) . ": $e->{documentation}\n";
        }
    } else {
        $out .= "(no matching best-practice sources)\n";
    }
    return $out;
}

# Canonical per-task scratch .out path. Delegates to the shared scratch_dir
# helper (Task 229) — EUID-derived base + the two-level 0700 first-use guard +
# symlink reject — so this script has a single derivation point in common with
# every other writer. Any failure maps to this script's warn+exit-1 convention,
# augmented with scratch_fail_hint so a base-not-writable / planted-symlink cause
# is named rather than left as a bare kind token.
sub scratch_out_path {
    my ($scratch, $kind) = scratch_dir($opt{task_num});
    unless (defined $scratch) {
        my $hint = scratch_fail_hint($kind);
        warn "$PROG: scratch unavailable ($kind)" . ($hint ? ": $hint" : '') . "\n";
        exit 1;
    }
    return "$scratch/best-practice-context-$opt{phase}.out";
}

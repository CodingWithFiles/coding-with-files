#!/usr/bin/env perl
#
# template-copier-v2.1 - Copy and populate template files for CIG tasks (v2.1 format)
#
# Usage: template-copier-v2.1 --task-type=TYPE --task-num=NUM --description=DESC [--destination=PATH] [--baseline-commit=SHA] [--format=json]
#
# v2.1 changes:
#   - Uses 10-phase workflow (a-j) with explicit execution phases
#   - Supports e-implementation-exec.md and g-testing-exec.md templates
#
# Parameters:
#   --task-type=TYPE     Task type (feature, bugfix, hotfix, chore, discovery)
#   --destination=PATH   Full path to task directory (optional, auto-constructed if omitted)
#   --task-num=NUM       Task number (e.g., "17", "1.2.3")
#   --description=DESC   Task description/slug
#   --baseline-commit=SHA Optional 40-char git SHA recorded in a-task-plan.md as the
#                        anchor for security-review changeset construction
#   --format=FORMAT      Output format: markdown (default) or json
#   --help               Show this help message
#
# Examples:
#   template-copier-v2.1 --task-type=feature --destination=/tmp/test --task-num=17 --description="test task"
#   template-copier-v2.1 --task-type=bugfix --destination=/tmp/test --task-num=1.2 --description="test" --format=json
#
# Exit codes:
#   0 - Success (files copied and substituted)
#   1 - Invalid arguments (bad task-type, missing param, invalid format)
#   2 - Not found (template directory missing, pool file missing)
#   3 - Permission error (can't read templates or write to destination)

use strict;
use warnings;
use utf8;
use FindBin;
use lib "$FindBin::Bin/../../lib";
use File::Basename qw(basename dirname);
use File::Spec;
use File::Path qw(make_path);
use Cwd qw(abs_path);
use CWF::TaskPath qw(validate get_parent resolve_num);
use CWF::WorkflowFiles qw(load_config);
use CWF::Common qw(generate_slug);

sub die_msg {
    print STDERR "[CWF] ERROR: @_\n";
    exit 1;
}

use constant SLUG_MAX_LEN => 50;

# Parse command-line parameters
sub parse_parameters {
    my @args = @_;
    my %params = (format => 'markdown');  # Default format

    for my $arg (@args) {
        if ($arg eq '--help') {
            print_usage();
            exit 0;
        } elsif ($arg =~ /^--task-type=(.+)$/) {
            $params{task_type} = $1;
        } elsif ($arg =~ /^--destination=(.+)$/) {
            $params{destination} = $1;
        } elsif ($arg =~ /^--task-num=(.+)$/) {
            $params{task_num} = $1;
        } elsif ($arg =~ /^--description=(.+)$/) {
            $params{description} = $1;
        } elsif ($arg =~ /^--baseline-commit=(.+)$/) {
            $params{baseline_commit} = $1;
        } elsif ($arg =~ /^--format=(.+)$/) {
            $params{format} = $1;
        } else {
            print STDERR "Error: Unknown argument: $arg\n";
            print STDERR "Use --help for usage information\n";
            exit 1;
        }
    }

    # Validate required parameters (destination now optional)
    my %param_names = (
        task_type => 'task-type',
        destination => 'destination',
        task_num => 'task-num',
        description => 'description'
    );

    for my $required (qw(task_type task_num description)) {
        unless (exists $params{$required}) {
            my $param_name = $param_names{$required};
            print STDERR "Error: Missing required parameter --$param_name\n";
            print STDERR "Use --help for usage information\n";
            exit 1;
        }
    }

    # Validate slug length before any filesystem work, so rejection is atomic.
    my $slug = generate_slug($params{description});
    my $slug_len = length($slug);
    if ($slug_len == 0) {
        die_msg("Task description '$params{description}' produces an empty slug after normalising. "
              . "Use a description that contains at least one alphanumeric character.");
    }
    if ($slug_len > SLUG_MAX_LEN) {
        die_msg("Task slug '$slug' is $slug_len characters; limit is " . SLUG_MAX_LEN . ". "
              . "Use a briefer task description (try fewer or shorter words).");
    }

    # Construct destination if not provided. Reuse the slug we just computed
    # rather than slugifying the description a second time.
    unless (exists $params{destination}) {
        $params{destination} = construct_destination(\%params, $slug);
    }

    # Validate format parameter
    unless ($params{format} eq 'markdown' || $params{format} eq 'json') {
        print STDERR "Error: Invalid format '$params{format}'\n";
        print STDERR "Supported formats: markdown, json\n";
        exit 1;
    }

    return %params;
}

# Print usage information
sub print_usage {
    print <<'USAGE';
template-copier-v2.1 - Copy and populate template files for CIG tasks (v2.1 format)

Usage: template-copier-v2.1 --task-type=TYPE --destination=PATH --task-num=NUM --description=DESC [--baseline-commit=SHA] [--format=json]

Parameters:
  --task-type=TYPE     Task type (feature, bugfix, hotfix, chore, discovery)
  --destination=PATH   Full path to task directory
  --task-num=NUM       Task number (e.g., "17", "1.2.3")
  --description=DESC   Task description/slug
  --baseline-commit=SHA Optional 40-char git SHA recorded in a-task-plan.md as the
                       anchor for security-review changeset construction
  --format=FORMAT      Output format: markdown (default) or json
  --help               Show this help message

Examples:
  template-copier-v2.1 --task-type=feature --destination=/tmp/test --task-num=17 --description="test task"
  template-copier-v2.1 --task-type=bugfix --destination=/tmp/test --task-num=1.2 --description="test" --format=json

Exit codes:
  0 - Success
  1 - Invalid arguments
  2 - Not found
  3 - Permission error
USAGE
    return;
}

# Find git repository root and templates directory
sub find_templates_directory {
    # Try git to find repository root
    my $git_root = `git rev-parse --show-toplevel 2>/dev/null`;
    chomp $git_root;

    my $templates_dir;

    if ($git_root && -d "$git_root/.cwf/templates") {
        $templates_dir = "$git_root/.cwf/templates";
    } elsif (-d ".cwf/templates") {
        $templates_dir = ".cwf/templates";
    } elsif (-d "../.cwf/templates") {
        $templates_dir = "../.cwf/templates";
    } elsif (-d "../../.cwf/templates") {
        $templates_dir = "../../.cwf/templates";
    } else {
        print STDERR "Error: Templates directory not found\n";
        print STDERR "Searched: .cwf/templates, ../.cwf/templates, ../../.cwf/templates\n";
        exit 2;
    }

    return abs_path($templates_dir);
}

# generate_slug() lifted to CWF::Common for shared use with backlog-manager;
# imported via `use CWF::Common qw(generate_slug)` above.

# Construct destination path from config pattern if not provided
# Subtasks (dotted numbers) are nested inside their parent directory
sub construct_destination {
    my ($params, $slug) = @_;

    my $config = load_config();
    unless ($config) {
        print STDERR "Error: Failed to load config\n";
        exit 2;
    }

    my $base_path = $config->{directory_structure}{base_path} || 'implementation-guide';
    $slug //= generate_slug($params->{description});
    my $task_dir = "$params->{task_num}-$params->{task_type}-$slug";

    # If subtask (has dots), nest inside parent directory
    if ($params->{task_num} =~ /\./) {
        my $parent_num = get_parent($params->{task_num});
        if ($parent_num) {
            my $parent = resolve_num($parent_num);
            if ($parent) {
                return "$parent->{full_path}/$task_dir";
            }
        }
    }

    return "$base_path/$task_dir";
}

# Validate task type against config
sub validate_task_type {
    my ($type) = @_;

    my $config = load_config();
    unless ($config) {
        print STDERR "Error: Cannot load CIG configuration\n";
        exit 1;
    }

    my @supported_types = @{$config->{'supported-task-types'} // [qw(feature bugfix hotfix chore discovery)]};
    unless (grep { $_ eq $type } @supported_types) {
        print STDERR "Error: Invalid task type '$type'\n";
        print STDERR "Supported types: " . join(", ", @supported_types) . "\n";
        exit 1;
    }

    return $config;
}

# Discover template files for a task type
sub discover_templates {
    my ($base, $type) = @_;

    my $type_dir = "$base/$type";
    unless (-d $type_dir) {
        print STDERR "Error: Template directory not found: $type_dir\n";
        exit 2;
    }

    opendir(my $dh, $type_dir) or do {
        print STDERR "Error: Cannot read template directory: $type_dir\n";
        print STDERR "Reason: $!\n";
        exit 3;
    };

    my @templates;
    while (my $file = readdir($dh)) {
        next unless $file =~ /\.template$/;

        my $symlink_path = "$type_dir/$file";
        unless (-l $symlink_path) {
            next;  # Skip non-symlinks
        }

        my $target = readlink($symlink_path);
        unless ($target) {
            print STDERR "Error: Cannot read symlink: $symlink_path\n";
            exit 2;
        }

        # Resolve target relative to type directory
        my $pool_file = File::Spec->rel2abs($target, $type_dir);
        unless (-f $pool_file) {
            print STDERR "Error: Broken symlink detected\n";
            print STDERR "Symlink: $symlink_path\n";
            print STDERR "Target: $pool_file (not found)\n";
            exit 2;
        }

        push @templates, {
            name => $file,
            pool_file => $pool_file
        };
    }

    closedir($dh);

    # Sort templates alphabetically for consistent ordering
    @templates = sort { $a->{name} cmp $b->{name} } @templates;

    return @templates;
}

# Get phase sequence from symlinks for a task type
sub get_phase_sequence {
    my ($templates_dir, $task_type) = @_;

    my $type_dir = "$templates_dir/$task_type";
    return () unless -d $type_dir;

    opendir(my $dh, $type_dir) or return ();

    my @phases;
    while (my $file = readdir($dh)) {
        # Extract phase letter from filename (e.g., "a-task-plan.md.template" -> "a")
        if ($file =~ /^([a-j])-.*\.template$/) {
            push @phases, $1;
        }
    }

    closedir($dh);

    # Sort alphabetically to get sequence
    my @sorted = sort @phases;
    return @sorted;
}

# Compute next action based on current phase and task type
sub compute_next_action {
    my ($templates_dir, $task_type, $template_file) = @_;

    # Extract phase letter from template filename
    my ($phase) = $template_file =~ /^([a-j])-/;
    return "Begin next phase" unless $phase;

    # Get sequence for this task type
    my @sequence = get_phase_sequence($templates_dir, $task_type);
    return "Unknown task type" unless @sequence;

    # Find current phase index
    my $current_idx;
    for my $i (0..$#sequence) {
        if ($sequence[$i] eq $phase) {
            $current_idx = $i;
            last;
        }
    }

    return "Unknown phase" unless defined $current_idx;

    # If last phase, return completion message
    if ($current_idx >= $#sequence) {
        return "Task complete";
    }

    # Get next phase letter
    my $next_phase = $sequence[$current_idx + 1];

    # Discover template filename for next phase
    my @templates = discover_templates($templates_dir, $task_type);
    my $next_file;
    for my $t (@templates) {
        if ($t->{name} =~ /^$next_phase-/) {
            $next_file = $t->{name};
            last;
        }
    }
    return "Next phase template not found" unless $next_file;

    # Transform filename to command
    my $command_name = $next_file;
    $command_name =~ s/^[a-j]-//;              # Remove phase prefix
    $command_name =~ s/\.md\.template$//;      # Remove extension
    my $command = "/cwf-" . $command_name;     # Prepend /cwf-

    return $command;
}

# Compute template variables
sub compute_variables {
    my ($params) = @_;

    my %vars;

    # Simple variables
    $vars{description} = $params->{description};
    $vars{taskId} = "internal-" . $params->{task_num};
    $vars{taskUrl} = "N/A (internal task)";

    # Parent task computation
    my $parent = get_parent($params->{task_num});
    $vars{parentTask} = $parent ? $parent : "N/A";

    # Branch name from config pattern
    my $config = load_config();
    my $pattern = $config->{'source-management'}{'branch-naming-convention'} // '';

    # Extract slug from destination basename
    my $basename = basename($params->{destination});
    my $slug;
    if ($basename =~ /^\d+-[^-]+-(.+)$/) {
        $slug = $1;
    } else {
        # Fallback to description if basename doesn't match pattern
        $slug = $params->{description};
    }

    # Substitute variables in branch pattern (config uses single-brace placeholders)
    my $branch = $pattern;
    $branch =~ s/\{task-type\}/$params->{task_type}/g;
    $branch =~ s/\{task-id\}/$params->{task_num}/g;
    $branch =~ s/\{description-slug\}/$slug/g;
    $vars{branchName} = $branch;

    # Add new template variables
    $vars{taskNum} = $params->{task_num};
    $vars{taskType} = $params->{task_type};
    $vars{baselineCommit} = $params->{baseline_commit} // '';

    return %vars;
}

# Substitute template variables in content
sub substitute_variables {
    my ($content, $vars) = @_;

    for my $key (keys %$vars) {
        my $value = $vars->{$key} // '';
        $content =~ s/\{\{$key\}\}/$value/g;
    }

    return $content;
}

# Transform template name to CIG command
sub name_to_action {
    my $template = shift;
    return unless defined $template;
    my $name = $template->{name};
    $name =~ s/^[a-z]-//;
    $name =~ s/\.md\.template$//;
    return "/cwf-" . $name;
}

# Copy templates to destination with variable substitution
sub copy_templates {
    my ($templates, $dest, $vars, $templates_dir, $task_type) = @_;

    my @created;
    my @overwritten;

    # Create destination directory if it doesn't exist
    unless (-d $dest) {
        make_path($dest) or do {
            print STDERR "Error: Cannot create destination directory: $dest\n";
            print STDERR "Reason: $!\n";
            exit 3;
        };
    }

    while (@$templates) {
        my $template = shift @$templates;
        my $pool_file = $template->{pool_file};
        my $filename = $template->{name};

        # Remove .template extension for destination
        $filename =~ s/\.template$//;
        my $dest_file = "$dest/$filename";

        # Read pool template
        open(my $fh, '<', $pool_file) or do {
            print STDERR "Error: Cannot read template file: $pool_file\n";
            print STDERR "Reason: $!\n";
            exit 3;
        };

        my $content = do { local $/; <$fh> };
        close($fh);

        # Compute nextAction by peeking at next template in queue
        my %template_vars = %$vars;  # Copy vars
        $template_vars{nextAction} = name_to_action($templates->[0]) // "Task complete";

        # Substitute variables
        $content = substitute_variables($content, \%template_vars);

        # Check if file exists (for idempotency tracking)
        my $exists = -f $dest_file;

        # Write atomically using temp file + rename
        my $temp_file = "$dest_file.tmp.$$";
        open(my $out, '>', $temp_file) or do {
            print STDERR "Error: Cannot write to destination: $temp_file\n";
            print STDERR "Reason: $!\n";
            exit 3;
        };

        print $out $content;
        close($out);

        # Set permissions before rename
        chmod 0600, $temp_file;

        # Atomic rename
        rename $temp_file, $dest_file or do {
            unlink $temp_file;
            print STDERR "Error: Cannot rename temp file: $temp_file -> $dest_file\n";
            print STDERR "Reason: $!\n";
            exit 3;
        };

        # Track created vs overwritten
        if ($exists) {
            print STDERR "Warning: Overwriting existing file: $dest_file\n";
            push @overwritten, $filename;
        } else {
            push @created, $filename;
        }
    }

    return (\@created, \@overwritten);
}

# Output results in requested format
sub output_results {
    my ($params, $created, $overwritten) = @_;

    my $total = @$created + @$overwritten;

    if ($params->{format} eq 'json') {
        # JSON output
        print "{\n";
        print qq(  "destination": "$params->{destination}",\n);
        print qq(  "task_type": "$params->{task_type}",\n);
        print qq(  "task_num": "$params->{task_num}",\n);
        print qq(  "files_created": [);
        print join(", ", map { qq("$_") } @$created);
        print "],\n";
        print qq(  "files_overwritten": [);
        print join(", ", map { qq("$_") } @$overwritten);
        print "],\n";
        print qq(  "warnings": );
        if (@$overwritten) {
            print "[\"Overwritten " . scalar(@$overwritten) . " existing file(s)\"]";
        } else {
            print "[]";
        }
        print ",\n";
        print qq(  "total_files": $total\n);
        print "}\n";
    } else {
        # Markdown output
        print "Template files copied to: $params->{destination}\n";

        if (@$created) {
            print "Files created:\n";
            for my $file (@$created) {
                print "  - $file\n";
            }
        }

        if (@$overwritten) {
            print "Files overwritten:\n";
            for my $file (@$overwritten) {
                print "  - $file\n";
            }
        }

        print "\nTotal: $total files copied\n";
    }
    return;
}

# Main execution
sub main {
    my %params = parse_parameters(@ARGV);
    my $templates_dir = find_templates_directory();
    my $config = validate_task_type($params{task_type});
    my @templates = discover_templates($templates_dir, $params{task_type});
    my %variables = compute_variables(\%params);
    my ($created, $overwritten) = copy_templates(\@templates, $params{destination}, \%variables, $templates_dir, $params{task_type});
    output_results(\%params, $created, $overwritten);
    return;
}

main() unless caller();

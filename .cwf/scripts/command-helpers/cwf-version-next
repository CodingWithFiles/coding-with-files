#!/usr/bin/env perl
use strict;
use warnings;
use utf8;
use FindBin;
use lib "$FindBin::Bin/../../lib";
use CWF::Versioning qw(next_version is_subtask_num);

my $PROG = 'cwf-version-next';

sub usage {
    "Usage: $PROG --task-num=N\n"
  . "  Prints the next version computed from versioning.major_minor + N.\n"
  . "  A subtask number (e.g. 3.2) is a no-op: version actions apply to top-level tasks only.\n"
  . "  See .cwf/docs/workflow/versioning-standard.md for details.\n";
}

my $task_num;
for (@ARGV) {
    if (/^--task-num=(\d+(?:\.\d+)*)$/) {
        my $n = $1;
        if (is_subtask_num($n)) {
            print "skipped: version actions apply to top-level tasks only (subtask $n)\n";
            exit 0;
        }
        $task_num = $n + 0;
        next;
    }
    if ($_ eq '--help' || $_ eq '-h') { print usage(); exit 0 }
    warn "$PROG: unknown argument: $_\n", usage();
    exit 1;
}

unless (defined $task_num && $task_num > 0) {
    warn usage();
    exit 1;
}

my $next = eval { next_version(task_num => $task_num) };
if ($@) { warn "$PROG: $@"; exit 1 }

print "$next\n";
exit 0;

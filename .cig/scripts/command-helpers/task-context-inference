#!/usr/bin/env perl
#
# task-context-inference - Infer current task and workflow step from signals
#
# USAGE:
#   task-context-inference [--verbose]
#
# DESCRIPTION:
#   Infers the current task number, slug, and workflow step by correlating
#   multiple environmental signals:
#   - Git branch name (feature/32-slug pattern)
#   - Worktree context (directory isolation)
#   - State file (.cig/current-task)
#   - File recency (recently modified tasks)
#   - Task progress (work potential using cliff function)
#
# OUTPUT:
#   Simple mode (default):
#     task_num: 32
#     task_slug: task-tracking-using-inference-scoring
#     workflow_step: f-implementation-exec
#
#   Verbose mode (--verbose):
#     Same as simple, plus signal breakdown showing:
#     - Each signal's top candidate and score
#     - Correlation status (ALL SIGNALS AGREE or SIGNALS DISAGREE)
#
# EXIT CODES:
#   0 - Success: all signals correlated
#   1 - Uncorrelated: signals disagree (user prompt shown)
#   2 - Error: exception during inference or invalid data
#   3 - No signals: cannot infer context
#
# EXAMPLES:
#   # Simple output for command integration
#   task-context-inference
#
#   # Verbose output for debugging
#   task-context-inference --verbose
#
#   # Check exit code for correlation status
#   if task-context-inference >/dev/null; then
#     echo "Signals correlated"
#   fi
#
#   # Extract task number for script use
#   TASK=$(task-context-inference | grep '^task_num:' | cut -d' ' -f2)
#
# SEE ALSO:
#   TaskContextInference.pm - Library implementing inference logic
#   .cig/docs/context/state-tracking.md - Signal descriptions and weights
#

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../../lib";

use TaskContextInference qw(infer_task_context);

# Parse command line arguments
my $verbose = 0;
for my $arg (@ARGV) {
    $verbose = 1 if $arg eq '--verbose';
}

# Call library function
my $context = eval { infer_task_context(verbose => $verbose) };

if ($@) {
    # Exception occurred during inference
    print STDERR "Error: $@\n";
    exit 2;
}

# Validate context is a hash reference
if (!$context || ref($context) ne 'HASH') {
    print STDERR "Error: Invalid context returned from library\n";
    exit 2;
}

# Print output
print $context->{output};

# Exit with appropriate code based on confidence
if ($context->{confidence} eq 'correlated') {
    exit 0;  # Success
} elsif ($context->{confidence} eq 'uncorrelated') {
    exit 1;  # Signals disagree, user prompt shown
} elsif ($context->{confidence} eq 'no_signals') {
    exit 3;  # Cannot infer (no signals detected)
} else {
    exit 2;  # Error or unknown confidence
}

#!/usr/bin/env perl
#
# status-aggregator - Entry point for status aggregation (trampolines to version-specific script)
#
# Usage: status-aggregator [task-path] [--workflow] [--no-workflow] [--limit=N] [--sort=modified] [--format=json]
#
# Intelligent Defaults:
#   - With task path: Auto-enables --workflow (unless --no-workflow specified)
#   - Without args: Auto-enables --sort=modified --limit=5 (unless explicit flags)
#

use strict;
use warnings;
use FindBin;

# Check PERL5OPT configuration
unless ($ENV{PERL5OPT} && $ENV{PERL5OPT} =~ /-C/) {
    warn "WARNING: PERL5OPT not configured for Unicode handling.\n";
    warn "Add the following to ~/.claude/settings.json:\n";
    warn "  \"env\": { \"PERL5OPT\": \"-CDSL\" }\n\n";
}
use lib "$FindBin::Bin/../../../lib";

use CIG::TaskPath qw(resolve);

# Detect version by resolving task path
sub detect_version {
    my $task_arg = shift || '';

    # If specific task provided, detect its format
    if ($task_arg && $task_arg =~ /^\d+(\.\d+)*$/) {
        my $result = resolve($task_arg);
        return "v$result->{format}" if $result;
    }

    # No task specified: default to v2.0
    return 'v2.0';
}

# Parse arguments to separate flags from task path
sub parse_arguments {
    my @args = @_;

    my %flags = (
        workflow => 0,
        no_workflow => 0,
        limit => undef,
        sort => undef,
        format => undef,
    );

    my $task_path = '';
    my @other_args;

    for my $arg (@args) {
        if ($arg eq '--workflow' || $arg eq '-w') {
            $flags{workflow} = 1;
        } elsif ($arg eq '--no-workflow') {
            $flags{no_workflow} = 1;
        } elsif ($arg =~ /^--limit=(.+)$/) {
            $flags{limit} = $1;
        } elsif ($arg =~ /^--sort=(.+)$/) {
            $flags{sort} = $1;
        } elsif ($arg =~ /^--format=(.+)$/) {
            $flags{format} = $1;
        } elsif ($arg =~ /^--/) {
            # Other flags (--help, --depth, etc.) pass through
            push @other_args, $arg;
        } elsif ($arg !~ /^-/ && !$task_path) {
            # First non-flag argument is task path
            $task_path = $arg;
        } else {
            push @other_args, $arg;
        }
    }

    return (\%flags, $task_path, \@other_args);
}

# Main: Parse arguments and apply intelligent defaults
my ($flags, $task_path, $other_args) = parse_arguments(@ARGV);

# Intelligent defaults logic
my @final_args;

# If task path provided AND no explicit --workflow/--no-workflow → Apply --workflow default
if ($task_path && !$flags->{workflow} && !$flags->{no_workflow}) {
    $flags->{workflow} = 1;
}

# If no arguments AND no explicit flags → Apply --sort=modified --limit=5 defaults
if (!$task_path && !$flags->{workflow} && !$flags->{no_workflow} &&
    !defined $flags->{limit} && !defined $flags->{sort}) {
    $flags->{sort} = 'modified';
    $flags->{limit} = 5;
}

# Build final argument list
push @final_args, $task_path if $task_path;
push @final_args, '--workflow' if $flags->{workflow};
push @final_args, '--no-workflow' if $flags->{no_workflow};
push @final_args, "--limit=$flags->{limit}" if defined $flags->{limit};
push @final_args, "--sort=$flags->{sort}" if defined $flags->{sort};
push @final_args, "--format=$flags->{format}" if defined $flags->{format};
push @final_args, @$other_args;

# Detect version and trampoline to appropriate orchestration script
my $version = detect_version($task_path);

# Note: We're in workflow-manager.d/, so parent dir is command-helpers/
my $parent_dir = "$FindBin::Bin/..";

if ($version eq 'v2.1') {
    exec("$parent_dir/status-aggregator-v2.1", @final_args);
} elsif ($version eq 'v2.0') {
    exec("$parent_dir/status-aggregator-v2.0", @final_args);
} elsif ($version eq 'v1.0') {
    die "ERROR: v1.0 format deprecated. Use migration tools to upgrade to v2.0.\n";
} else {
    die "ERROR: Unknown format version: $version\n";
}

# If exec fails
die "Error: Failed to execute status-aggregator-$version\n";
